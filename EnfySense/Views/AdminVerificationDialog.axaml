<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EnfyLiveScreenClient.Views.AdminVerificationDialog"
        Title="Administrator Verification"
        Width="400" Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0B1220"
        SystemDecorations="None"
        BorderBrush="#1F2937"
        BorderThickness="1"
        CornerRadius="12">

  <Border Padding="30" Background="#111827" CornerRadius="12">
    <StackPanel Spacing="20">
      <StackPanel Spacing="8">
        <TextBlock Text="Administrator Required" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Foreground="White" 
                   HorizontalAlignment="Center" />
        <TextBlock Text="Enter the 6-digit code from your Authenticator app to continue." 
                   Foreground="#94A3B8" 
                   FontSize="13" 
                   TextAlignment="Center" 
                   TextWrapping="Wrap" />
      </StackPanel>

      <TextBox Name="CodeInput" 
               Width="200" 
               Height="50"
               FontSize="24"
               FontWeight="Bold"
               LetterSpacing="8"
               TextAlignment="Center"
               MaxLength="6"
               Watermark="000000"
               Foreground="White"
               Background="#1E293B"
               BorderBrush="#3B82F6"
               HorizontalAlignment="Center" />

      <TextBlock Name="ErrorText" 
                 Text="Invalid code. Please try again." 
                 Foreground="#EF4444" 
                 FontSize="12" 
                 HorizontalAlignment="Center" 
                 IsVisible="False" />

      <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
        <Button Grid.Column="0" 
                Content="Cancel" 
                Click="OnCancelClick"
                HorizontalAlignment="Stretch"
                Margin="0,0,5,0"
                Padding="15,10"
                Background="#1E293B"
                Foreground="#94A3B8" />
        <Button Grid.Column="1" 
                Content="Verify" 
                Click="OnVerifyClick"
                IsDefault="True"
                HorizontalAlignment="Stretch"
                Margin="5,0,0,0"
                Padding="15,10"
                Background="#3B82F6"
                Foreground="White"
                FontWeight="Bold" />
      </Grid>
    </StackPanel>
  </Border>
</Window>
