<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EnfyLiveScreenClient.Views.InactivityPromptWindow"
        Title="Inactivity Check"
        Width="400" Height="280"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False">

  <Border Padding="32" 
          Background="#1E293B" 
          CornerRadius="24" 
          BorderBrush="#475569" 
          BorderThickness="1"
          BoxShadow="0 20 50 0 #40000000">
    <StackPanel Spacing="24" VerticalAlignment="Center">
      <StackPanel Spacing="8">
        <TextBlock Text="Are you still working?" 
                   FontSize="22" 
                   FontWeight="Black" 
                   Foreground="White" 
                   HorizontalAlignment="Center" />
        <TextBlock Text="Inactivity detected for 5 minutes. Please confirm your status." 
                   Foreground="#94A3B8" 
                   FontSize="13" 
                   TextAlignment="Center" 
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Name="TimerText" 
                   Text="30" 
                   FontSize="48" 
                   FontWeight="Black" 
                   Foreground="#6366F1" 
                   HorizontalAlignment="Center" />
        <TextBlock Text="seconds remaining" 
                   FontSize="11" 
                   FontWeight="Bold" 
                   Foreground="#475569" 
                   HorizontalAlignment="Center" 
                   Classes="uppercase" />
      </StackPanel>

      <Button Name="ConfirmButton"
              Content="Yes, I am working" 
              Click="OnConfirmClick"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Padding="0,16"
              Background="#6366F1"
              Foreground="White"
              FontWeight="Bold"
              FontSize="15"
              CornerRadius="12">
        <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4F46E5" />
            <Setter Property="TextElement.Foreground" Value="White" />
          </Style>
        </Button.Styles>
      </Button>
    </StackPanel>
  </Border>
</Window>
