<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EnfyLiveScreenClient.Views.InactivityPromptWindow"
        Title="Inactivity Check"
        WindowState="FullScreen"
        Background="#E6EF4444" 
        Topmost="True"
        ShowInTaskbar="False">

  <Border Padding="40" 
          Background="#1E293B" 
          CornerRadius="24" 
          BorderBrush="#EF4444" 
          BorderThickness="2"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          BoxShadow="0 20 50 0 #80000000">
    <StackPanel Spacing="24" VerticalAlignment="Center">
      <StackPanel Spacing="8">
        <TextBlock Text="Are you still working?" 
                   FontSize="22" 
                   FontWeight="Black" 
                   Foreground="White" 
                   HorizontalAlignment="Center" />
        <TextBlock Name="DescriptionText"
                   Text="Inactivity detected. Please confirm your status." 
                   Foreground="#94A3B8" 
                   FontSize="16" 
                   TextAlignment="Center" 
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Name="TimerText" 
                   Text="30" 
                   FontSize="64" 
                   FontWeight="Black" 
                   Foreground="#EF4444" 
                   HorizontalAlignment="Center" />
        <TextBlock Text="seconds remaining" 
                   FontSize="11" 
                   FontWeight="Bold" 
                   Foreground="#475569" 
                   HorizontalAlignment="Center" 
                   Classes="uppercase" />
      </StackPanel>

      <Button Name="ConfirmButton"
              Content="YES, I AM WORKING" 
              Click="OnConfirmClick"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              Padding="0,20"
              Background="#EF4444"
              Foreground="White"
              FontWeight="Black"
              FontSize="18"
              CornerRadius="16">
        <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4F46E5" />
            <Setter Property="TextElement.Foreground" Value="White" />
          </Style>
        </Button.Styles>
      </Button>
    </StackPanel>
  </Border>
</Window>
