<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EnfyLiveScreenClient.ViewModels"
        x:Class="EnfyLiveScreenClient.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100"
        Height="720"
        MinWidth="1000"
        MinHeight="650"
        Title="EnfySense"
        Background="#0B1220"
        WindowStartupLocation="CenterScreen"
        Classes.overlayVisible="{Binding IsOverlayVisible}">

  <Window.Resources>
    <ResourceDictionary>
      <vm:StatusColorConverter x:Key="StatusColorConverter" />
      <vm:PauseToResumeConverter x:Key="PauseToResumeConverter" />
      <vm:StatusPulseConverter x:Key="StatusPulseConverter" />
      <vm:DarkenColorConverter x:Key="DarkenColorConverter" />
    </ResourceDictionary>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#111827" />
      <Setter Property="BorderBrush" Value="#1F2937" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F8FAFC" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.action:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.01)" />
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
       <Setter Property="Background" Value="{Binding $parent[Button].Background, Converter={StaticResource DarkenColorConverter}}" />
    </Style>
    <Style Selector="Grid#MainGrid">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window.overlayVisible Grid#MainGrid">
      <Setter Property="Effect">
        <Setter.Value>
          <BlurEffect Radius="15" />
        </Setter.Value>
      </Setter>
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="Border.chart-bar">
      <Setter Property="RenderTransformOrigin" Value="50%,100%" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Height" Duration="0:0:0.5" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
  </Window.Styles>

  <Panel>
    <Grid Name="MainGrid" RowDefinitions="Auto, Auto, *">
      <!-- Top Navigation Bar -->
      <Border Height="80" Background="#111827" BorderBrush="#1F2937" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="320, *, Auto, Auto" Margin="24,0">
          
          <!-- Column 0: User Profile Section with Dropdown -->
          <Button Grid.Column="0" 
                  Background="Transparent" 
                  BorderThickness="0" 
                  Padding="0"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedLeft">
                <MenuItem Header="Check for Updates" Command="{Binding ManualCheckForUpdatesCommand}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource arrow_circle_up_regular}" Width="14" Height="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Settings" Command="{Binding SaveSettingsCommand}" IsVisible="{Binding IsAdminMode}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource building_regular}" Width="14" Height="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator IsVisible="{Binding IsAdminMode}" />
                <MenuItem Header="Sign Out" Command="{Binding LogoutCommand}" Foreground="#EF4444" IsVisible="{Binding IsAdminMode}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource user_regular}" Foreground="#EF4444" Width="14" Height="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Exit App" Command="{Binding ExitAppCommand}" Foreground="#EF4444" IsVisible="{Binding IsAdminMode}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource stop_regular}" Foreground="#EF4444" Width="14" Height="14" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator IsVisible="{Binding !IsAdminMode}" />
                <MenuItem Header="Unlock Admin Mode" Command="{Binding UnlockAdminCommand}" IsVisible="{Binding !IsAdminMode}">
                  <MenuItem.Icon>
                    <PathIcon Data="{StaticResource lock_regular}" Width="14" Height="14" />
                  </MenuItem.Icon>
                </MenuItem>
              </MenuFlyout>
            </Button.Flyout>
            
            <StackPanel Orientation="Horizontal" Spacing="16">
              <Border Width="44" Height="44" CornerRadius="22" Background="#1E293B">
                <PathIcon Data="{StaticResource user_regular}" Width="20" Height="20" Foreground="#94A3B8" />
              </Border>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentUser}" 
                           Foreground="#F8FAFC" 
                           FontWeight="SemiBold" 
                           FontSize="16"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                   <TextBlock Text="Manage Account" FontSize="11" Foreground="#64748B" />
                   <PathIcon Data="{StaticResource pause_regular}" Width="8" Height="8" Foreground="#64748B" Opacity="0.5" RenderTransform="rotate(90deg)" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Button>

          <!-- Admin Mode Indicator -->
          <Border Grid.Column="1" 
                  IsVisible="{Binding IsAdminMode}"
                  Background="#3B82F6" 
                  CornerRadius="20" 
                  Padding="12,6" 
                  VerticalAlignment="Center" 
                  HorizontalAlignment="Left" 
                  Margin="20,0">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <PathIcon Data="{StaticResource shield_regular}" Width="14" Height="14" Foreground="White" />
              <TextBlock Text="ADMIN MODE" Foreground="White" FontSize="11" FontWeight="Black" VerticalAlignment="Center" />
              <Border Width="1" Height="12" Background="White" Opacity="0.3" />
              <TextBlock Text="{Binding AdminRemainingDisplay}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
              <Button Command="{Binding LockAdminCommand}" 
                      Background="Transparent" 
                      Padding="4" 
                      Margin="4,0,0,0">
                <PathIcon Data="{StaticResource lock_regular}" Width="12" Height="12" Foreground="White" />
              </Button>
            </StackPanel>
          </Border>

          <!-- Column 2: Stats (Work/Break) -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="24" Margin="0,0,32,0" IsVisible="{Binding IsAuthenticated}">
            <StackPanel VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                <PathIcon Data="{StaticResource clock_regular}" Width="12" Height="12" Foreground="#10B981" />
                <TextBlock Text="WORK TODAY" FontSize="10" Foreground="#64748B" FontWeight="Bold" LetterSpacing="0.5" />
              </StackPanel>
              <TextBlock Text="{Binding WorkTodayDisplay}" FontSize="20" Foreground="#F8FAFC" FontWeight="Bold" />
            </StackPanel>

            <StackPanel VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                <PathIcon Data="{StaticResource shield_regular}" Width="12" Height="12" Foreground="#F43F5E" />
                <TextBlock Text="OVERTIME" FontSize="10" Foreground="#64748B" FontWeight="Bold" LetterSpacing="0.5" />
              </StackPanel>
              <TextBlock Text="{Binding OvertimeTodayDisplay}" FontSize="20" Foreground="#F8FAFC" FontWeight="Bold" />
            </StackPanel>

            <StackPanel VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                <PathIcon Data="{StaticResource pause_regular}" Width="12" Height="12" Foreground="#F59E0B" />
                <TextBlock Text="BREAK TODAY" FontSize="10" Foreground="#64748B" FontWeight="Bold" LetterSpacing="0.5" />
              </StackPanel>
              <TextBlock Text="{Binding BreakTodayDisplay}" FontSize="20" Foreground="#F8FAFC" FontWeight="Bold" />
            </StackPanel>
          </StackPanel>

          <!-- Column 3: Action Buttons -->
          <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12" IsVisible="{Binding IsAuthenticated}">
            <Button Classes="action" 
                    Command="{Binding StartTrackingCommand}"
                    IsVisible="{Binding CanShowStart}"
                    Background="#10B981" Foreground="White">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Data="{StaticResource play_regular}" Width="14" Height="14" />
                <TextBlock Text="{Binding IsPaused, Converter={StaticResource PauseToResumeConverter}}" />
              </StackPanel>
            </Button>

            <Button Classes="action" 
                    Command="{Binding PauseTrackingCommand}"
                    IsVisible="{Binding CanShowPause}"
                    Background="#F59E0B" Foreground="White">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Data="{StaticResource pause_regular}" Width="14" Height="14" />
                <TextBlock Text="Take a Break" />
              </StackPanel>
            </Button>

            <Button Classes="action" 
                    Command="{Binding RequestFinishWorkCommand}"
                    IsVisible="{Binding IsTrackingActive}"
                    Background="#EF4444" Foreground="White">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Data="{StaticResource stop_regular}" Width="14" Height="14" />
                <TextBlock Text="Finish" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Update Notification Bar -->
      <Border Grid.Row="1" Background="#3B82F6" IsVisible="{Binding IsUpdateAvailable}">
        <Grid ColumnDefinitions="*, Auto" Margin="24,10">
          <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <PathIcon Data="{StaticResource arrow_circle_up_regular}" Foreground="White" Width="18" Height="18" />
            <StackPanel Spacing="2">
              <TextBlock Text="A new update is ready! Restart now to stay up to date." 
                         Foreground="White" FontWeight="Medium" VerticalAlignment="Center" />
              <TextBlock Text="{Binding ReleaseNotes}" 
                         Foreground="#BFDBFE" FontSize="11" 
                         VerticalAlignment="Center" MaxWidth="600"
                         TextTrimming="CharacterEllipsis"
                         IsVisible="{Binding ReleaseNotes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <ToolTip.Tip>
                  <StackPanel Spacing="5" Margin="5">
                    <TextBlock Text="What's New:" FontWeight="Bold" Foreground="#3B82F6" />
                    <TextBlock Text="{Binding ReleaseNotes}" MaxWidth="400" TextWrapping="Wrap" />
                  </StackPanel>
                </ToolTip.Tip>
              </TextBlock>
            </StackPanel>
          </StackPanel>
          <Button Grid.Column="1" 
                  Command="{Binding ApplyUpdateCommand}" 
                  Background="White" 
                  Foreground="#3B82F6" 
                  Padding="16,6" 
                  CornerRadius="6">
            <TextBlock Text="Update &amp; Restart Now" FontSize="13" FontWeight="Bold" />
          </Button>
        </Grid>
      </Border>

      <!-- Main Content Area -->
      <ScrollViewer Grid.Row="2" IsVisible="{Binding IsAuthenticated}">
        <StackPanel Margin="24" Spacing="24">
          
          <!-- TOP CARDS ROW -->
          <Grid ColumnDefinitions="*, *, *, *" RowDefinitions="Auto">
            <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
              <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <Border Width="32" Height="32" CornerRadius="8" Background="#059669">
                      <PathIcon Data="{StaticResource building_regular}" Width="16" Height="16" Foreground="White" />
                   </Border>
                   <TextBlock Text="ORGANIZATION" Classes="label" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
                <TextBlock Text="{Binding OrgNameDisplay}" Foreground="#F8FAFC" FontSize="20" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                   <PathIcon Data="{StaticResource clock_regular}" Width="14" Height="14" Foreground="#059669" />
                   <TextBlock Text="{Binding TimezoneDisplay}" Foreground="#94A3B8" FontSize="13" />
                   <TextBlock Text="{Binding OrgTimeDisplay}" Foreground="#F8FAFC" FontSize="13" FontWeight="Bold" Margin="4,0,0,0"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Margin="12,0">
               <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <Border Width="32" Height="32" CornerRadius="8" Background="#3B82F6">
                      <PathIcon Data="{StaticResource clock_regular}" Width="16" Height="16" Foreground="White" />
                   </Border>
                   <TextBlock Text="WORK TIME TRACKING" Classes="label" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                   <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="TODAY" Classes="label" FontSize="10" />
                      <TextBlock Text="{Binding WorkTodayDisplay}" Foreground="#F8FAFC" FontSize="18" FontWeight="Bold" />
                   </StackPanel>
                   <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Text="THIS WEEK" Classes="label" FontSize="10" />
                      <TextBlock Text="{Binding WorkThisWeekDisplay}" Foreground="#3B82F6" FontSize="18" FontWeight="Bold" />
                   </StackPanel>
                   <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="#1F2937" Margin="0,12" />
                   <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,16,0,0">
                      <TextBlock Text="This Month" Classes="label" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding WorkThisMonthDisplay}" Foreground="#F8FAFC" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" Margin="80,0,0,0" />
                   </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Column="2" Classes="card" Margin="12,0">
              <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <Border Width="32" Height="32" CornerRadius="8" Background="#A855F7">
                      <PathIcon Data="{StaticResource cloud_regular}" Width="16" Height="16" Foreground="White" />
                   </Border>
                   <TextBlock Text="CLOUD SYNC" Classes="label" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                   <PathIcon Grid.Row="0" Grid.Column="0" Data="{StaticResource check_regular}" Width="14" Height="14" Foreground="#10B981" VerticalAlignment="Center" />
                   <TextBlock Grid.Row="0" Grid.Column="1" Text="Status" Classes="label" Margin="8,0,0,0" VerticalAlignment="Center" />
                   <TextBlock Grid.Row="0" Grid.Column="1" Text="Synced" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Right" />
                   
                   <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="#1F2937" Margin="0,12" />
                   
                   <PathIcon Grid.Row="1" Grid.Column="0" Data="{StaticResource clock_regular}" Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center" />
                   <TextBlock Grid.Row="1" Grid.Column="1" Text="Last Sync" Classes="label" Margin="8,0,0,0" VerticalAlignment="Center" />
                   <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastSyncDisplay}" Foreground="#F8FAFC" FontWeight="Bold" HorizontalAlignment="Right" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Column="3" Classes="card" Margin="12,0,0,0">
              <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <Border Width="32" Height="32" CornerRadius="8" Background="#F59E0B">
                      <PathIcon Data="{StaticResource star_regular}" Width="16" Height="16" Foreground="White" />
                   </Border>
                   <TextBlock Text="TODAY'S SUMMARY" Classes="label" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto">
                   <StackPanel Grid.Column="0" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                         <PathIcon Data="{StaticResource chart_regular}" Width="10" Height="10" Foreground="#F59E0B" />
                         <TextBlock Text="ACTIVITY SCORE" Classes="label" FontSize="10" FontWeight="Bold" />
                      </StackPanel>
                      <TextBlock Text="{Binding ActivityLevel}" Foreground="#FBBF24" FontSize="24" FontWeight="Bold" />
                   </StackPanel>
                   <StackPanel Grid.Column="1" Spacing="4">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                         <PathIcon Data="{StaticResource pause_regular}" Width="10" Height="10" Foreground="#3B82F6" />
                         <TextBlock Text="BREAKS" Classes="label" FontSize="10" FontWeight="Bold" />
                      </StackPanel>
                      <TextBlock Text="{Binding BreaksCount}" Foreground="#F8FAFC" FontSize="24" FontWeight="Bold" />
                   </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>

          <!-- STATS ROW -->
          <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="12">
             <Border Grid.Column="0" Classes="card" Padding="20,12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <PathIcon Data="{StaticResource chart_regular}" Width="16" Height="16" Foreground="#3B82F6" />
                   <StackPanel>
                      <TextBlock Text="LAST 7 DAYS" Classes="label" FontSize="9" FontWeight="Bold" />
                      <TextBlock Text="{Binding Last7DaysDisplay}" FontSize="24" FontWeight="Bold" />
                   </StackPanel>
                </StackPanel>
             </Border>
             <Border Grid.Column="1" Classes="card" Padding="20,12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <PathIcon Data="{StaticResource calendar_regular}" Width="16" Height="16" Foreground="#3B82F6" />
                   <StackPanel>
                      <TextBlock Text="LAST 30 DAYS" Classes="label" FontSize="9" FontWeight="Bold" />
                      <TextBlock Text="{Binding Last30DaysDisplay}" FontSize="24" FontWeight="Bold" />
                   </StackPanel>
                </StackPanel>
             </Border>
             <Border Grid.Column="2" Classes="card" Padding="20,12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <PathIcon Data="{StaticResource star_regular}" Width="16" Height="16" Foreground="#10B981" />
                   <StackPanel>
                      <TextBlock Text="AVG/DAY" Classes="label" FontSize="9" FontWeight="Bold" />
                      <TextBlock Text="{Binding AvgPerDayDisplay}" FontSize="24" FontWeight="Bold" />
                   </StackPanel>
                </StackPanel>
             </Border>
             <Border Grid.Column="3" Classes="card" Padding="20,12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                   <PathIcon Data="{StaticResource clock_regular}" Width="16" Height="16" Foreground="#A855F7" />
                   <StackPanel>
                      <TextBlock Text="TODAY" Classes="label" FontSize="9" FontWeight="Bold" />
                      <TextBlock Text="{Binding TodayHoursDisplay}" FontSize="24" FontWeight="Bold" />
                   </StackPanel>
                </StackPanel>
             </Border>
          </Grid>

          <!-- CHARTS ROW -->
          <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
             <Border Grid.Column="0" Classes="card" Height="300">
                <StackPanel Spacing="20">
                   <Grid ColumnDefinitions="Auto, *, Auto">
                      <Border Width="32" Height="32" CornerRadius="8" Background="#A855F7" Opacity="0.8">
                         <PathIcon Data="{StaticResource clock_regular}" Width="16" Height="16" Foreground="White" />
                      </Border>
                      <StackPanel Grid.Column="1" Margin="12,0">
                         <TextBlock Text="Today" FontWeight="Bold" Foreground="White" />
                         <TextBlock Text="Hourly breakdown" Classes="label" FontSize="10" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                         <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#3B82F6" />
                            <TextBlock Text="Work" Classes="label" FontSize="10" />
                         </StackPanel>
                         <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#FBBF24" />
                            <TextBlock Text="Break" Classes="label" FontSize="10" />
                         </StackPanel>
                         <PathIcon Data="{StaticResource arrow_circle_up_regular}" Width="14" Height="14" Foreground="#64748B" />
                      </StackPanel>
                   </Grid>
                   
                   <Grid ColumnDefinitions="50, *" Height="200">
                      <!-- Y-Axis Labels -->
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding HourlyYAxisLabels}" VerticalAlignment="Top" Margin="0,5,0,0">
                         <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                               <StackPanel Spacing="23" />
                            </ItemsPanelTemplate>
                         </ItemsControl.ItemsPanel>
                         <ItemsControl.ItemTemplate>
                            <DataTemplate>
                               <TextBlock Text="{Binding}" FontSize="9" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,0,8,0" />
                            </DataTemplate>
                         </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <Grid Grid.Column="1" VerticalAlignment="Stretch">
                         <!-- Grid Lines -->
                         <StackPanel Spacing="31" VerticalAlignment="Top" Margin="0,10,0,0">
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                         </StackPanel>
                         
                         <ItemsControl ItemsSource="{Binding HourlyActivityItems}" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                               <ItemsPanelTemplate>
                                  <UniformGrid Rows="1" Columns="24" VerticalAlignment="Bottom" />
                               </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                               <DataTemplate>
                                  <StackPanel VerticalAlignment="Bottom" Spacing="8">
                                     <Border Width="12" CornerRadius="2,2,0,0" ClipToBounds="True" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                         <StackPanel Spacing="0">
                                            <Border Classes="chart-bar" Height="{Binding BreakHeight}" Background="#FBBF24" />
                                            <Border Classes="chart-bar" Height="{Binding OvertimeHeight}" Background="#10B981" />
                                            <Border Classes="chart-bar" Height="{Binding WorkHeight}" Background="#3B82F6" />
                                         </StackPanel>
                                        <ToolTip.Tip><TextBlock Text="{Binding Tooltip}" /></ToolTip.Tip>
                                     </Border>
                                     <TextBlock Text="{Binding Day}" FontSize="8" Foreground="#64748B" HorizontalAlignment="Center" Height="10" />
                                  </StackPanel>
                               </DataTemplate>
                            </ItemsControl.ItemTemplate>
                         </ItemsControl>
                      </Grid>
                   </Grid>
                </StackPanel>
             </Border>

             <Border Grid.Column="1" Classes="card" Height="300">
                <StackPanel Spacing="20">
                   <Grid ColumnDefinitions="Auto, *, Auto">
                      <Border Width="32" Height="32" CornerRadius="8" Background="#06B6D4" Opacity="0.8">
                         <PathIcon Data="{StaticResource calendar_regular}" Width="16" Height="16" Foreground="White" />
                      </Border>
                      <StackPanel Grid.Column="1" Margin="12,0">
                         <TextBlock Text="Last 30 Days" FontWeight="Bold" Foreground="White" />
                         <TextBlock Text="Daily breakdown" Classes="label" FontSize="10" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                         <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#3B82F6" />
                            <TextBlock Text="Work" Classes="label" FontSize="10" />
                         </StackPanel>
                         <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#FBBF24" />
                            <TextBlock Text="Break" Classes="label" FontSize="10" />
                         </StackPanel>
                         <PathIcon Data="{StaticResource arrow_circle_up_regular}" Width="14" Height="14" Foreground="#64748B" />
                      </StackPanel>
                   </Grid>

                   <Grid ColumnDefinitions="50, *" Height="200">
                      <!-- Y-Axis Labels -->
                      <ItemsControl Grid.Column="0" ItemsSource="{Binding DailyYAxisLabels}" VerticalAlignment="Top" Margin="0,5,0,0">
                         <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                               <StackPanel Spacing="23" />
                            </ItemsPanelTemplate>
                         </ItemsControl.ItemsPanel>
                         <ItemsControl.ItemTemplate>
                            <DataTemplate>
                               <TextBlock Text="{Binding}" FontSize="9" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,0,8,0" />
                            </DataTemplate>
                         </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <Grid Grid.Column="1" VerticalAlignment="Stretch">
                         <!-- Grid Lines -->
                         <StackPanel Spacing="31" VerticalAlignment="Top" Margin="0,10,0,0">
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                            <Border Height="1" Background="#1F2937" Opacity="0.5" />
                         </StackPanel>
                         
                         <ItemsControl ItemsSource="{Binding DailyActivityItems}" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                               <ItemsPanelTemplate>
                                  <UniformGrid Rows="1" Columns="30" VerticalAlignment="Bottom" />
                               </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                               <DataTemplate>
                                  <StackPanel VerticalAlignment="Bottom" Spacing="8">
                                     <Border Width="8" CornerRadius="2,2,0,0" ClipToBounds="True" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                         <StackPanel Spacing="0">
                                            <Border Classes="chart-bar" Height="{Binding BreakHeight}" Background="#FBBF24" />
                                            <Border Classes="chart-bar" Height="{Binding OvertimeHeight}" Background="#10B981" />
                                            <Border Classes="chart-bar" Height="{Binding WorkHeight}" Background="#3B82F6" />
                                         </StackPanel>
                                        <ToolTip.Tip><TextBlock Text="{Binding Tooltip}" /></ToolTip.Tip>
                                     </Border>
                                     <TextBlock Text="{Binding Day}" FontSize="8" Foreground="#64748B" HorizontalAlignment="Center" Height="10" />
                                  </StackPanel>
                               </DataTemplate>
                            </ItemsControl.ItemTemplate>
                         </ItemsControl>
                      </Grid>
                   </Grid>
                </StackPanel>
             </Border>
          </Grid>

          <!-- Bottom Footer Info -->
          <Grid ColumnDefinitions="*, Auto">
             <StackPanel Orientation="Horizontal" Spacing="20">
               <StackPanel Orientation="Horizontal" Spacing="8">
                 <TextBlock Text="Connection:" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" />
                 <TextBlock Text="{Binding ConnectionStatus}" Foreground="#34D399" FontSize="11" VerticalAlignment="Center" />
               </StackPanel>
               <Border Width="1" Height="12" Background="#1F2937" VerticalAlignment="Center" />
               <StackPanel Orientation="Horizontal" Spacing="8">
                 <TextBlock Text="Device ID:" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" />
                 <SelectableTextBlock Text="{Binding DeviceId}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" />
               </StackPanel>
               <Border Width="1" Height="12" Background="#1F2937" VerticalAlignment="Center" />
               <StackPanel Orientation="Horizontal" Spacing="8">
                 <TextBlock Text="Version:" Foreground="#64748B" FontSize="11" VerticalAlignment="Center" />
                 <TextBlock Text="{Binding AppVersion}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" />
               </StackPanel>
             </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Post-Auth Login Redirect Overlay (Optional if logout used) -->
    <Border Background="#0B1220" IsVisible="{Binding !IsAuthenticated}">
       <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Spacing="40">
         <StackPanel Spacing="16">
            <TextBlock Text="EnfySense" FontSize="48" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
            <TextBlock Text="Premium Workplace Productivity" Foreground="#64748B" HorizontalAlignment="Center" FontSize="16" />
         </StackPanel>
         <Border Classes="card" Padding="40" Background="#111827">
            <StackPanel Spacing="32">
              <StackPanel Spacing="12">
                <TextBlock Text="Microsoft Sign-In" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" />
                <TextBlock Text="Sign in with your work account to connect the EnfySense." 
                           Foreground="#94A3B8" TextAlignment="Center" FontSize="13" TextWrapping="Wrap" />
              </StackPanel>
              <Button Command="{Binding LoginCommand}" Classes="action" HorizontalAlignment="Stretch" Background="#6366F1" Foreground="White" Padding="20">
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                  <PathIcon Data="{StaticResource user_regular}" Width="18" Height="18" />
                  <TextBlock Text="Continue with Microsoft" FontWeight="Bold" />
                </StackPanel>
              </Button>
              <TextBlock Text="{Binding StatusMessage}" Foreground="#EF4444" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
         </Border>
       </StackPanel>
    </Border>

    <!-- Maintenance Overlay -->
    <Border Background="#CC000000" IsVisible="{Binding IsMaintenanceActive}">
       <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
          <Border Background="#1E293B" Padding="30" CornerRadius="24" BorderBrush="#EF4444" BorderThickness="2">
             <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="⚠" FontSize="48" HorizontalAlignment="Center" Foreground="#EF4444" />
                <TextBlock Text="Maintenance Mode" FontSize="24" FontWeight="Bold" Foreground="#F8FAFC" />
                <TextBlock Text="This device is currently being serviced by an administrator." 
                           MaxWidth="300" TextWrapping="Wrap" TextAlignment="Center" Foreground="#94A3B8" />
             </StackPanel>
          </Border>
       </StackPanel>
    </Border>
    <!-- Applying Update Overlay -->
    <Border Background="#CC000000" IsVisible="{Binding IsApplyingUpdate}" ZIndex="1000">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
        <Border Background="#111827" BorderBrush="#3B82F6" BorderThickness="2" CornerRadius="24" Padding="40" Width="450">
          <StackPanel Spacing="32">
            <Grid Height="60" Width="60" HorizontalAlignment="Center">
               <!-- Simple spinning animation simulated by a PathIcon -->
               <PathIcon Data="{StaticResource arrow_circle_up_regular}" 
                         Width="60" Height="60" 
                         Foreground="#3B82F6">
                 <PathIcon.Styles>
                   <Style Selector="PathIcon">
                   </Style>
                 </PathIcon.Styles>
               </PathIcon>
            </Grid>
            
            <StackPanel Spacing="12">
              <TextBlock Text="Applying Update..." FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
              <TextBlock Text="The application is restarting to apply the latest changes. Please do not close the window." 
                         Foreground="#94A3B8" TextAlignment="Center" TextWrapping="Wrap" FontSize="14" LineHeight="22" />
            </StackPanel>
            
            <ProgressBar IsIndeterminate="True" Height="4" Background="#1F2937" Foreground="#3B82F6" CornerRadius="2" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <!-- Finish Work Confirmation Overlay -->
    <Border Background="#CC000000" IsVisible="{Binding ShowFinishConfirmation}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="16" Padding="32" Width="400">
          <StackPanel Spacing="24">
            <StackPanel Spacing="12">
              <TextBlock Text="Finish Work for the Day?" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
              <TextBlock Text="This will stop all tracking and mark you as inactive in the dashboard." 
                         Foreground="#94A3B8" TextAlignment="Center" TextWrapping="Wrap" FontSize="14" />
            </StackPanel>
            
            <Grid ColumnDefinitions="*, *" HorizontalAlignment="Center" Width="300" Margin="0,10,0,0">
              <Button Grid.Column="0" Command="{Binding CancelFinishWorkCommand}" 
                      Classes="action" Background="#1F2937" Foreground="White" Margin="0,0,10,0">
                <TextBlock Text="Cancel" />
              </Button>
              <Button Grid.Column="1" Command="{Binding ConfirmFinishCommand}" 
                      Classes="action" Background="#EF4444" Foreground="White">
                <TextBlock Text="Finish Work" />
              </Button>
            </Grid>
            
            <TextBlock Text="Tip: If you're just taking a break, use the 'Take a Break' button instead." 
                       FontSize="11" Foreground="#64748B" TextAlignment="Center" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>
  </Panel>
</Window>


