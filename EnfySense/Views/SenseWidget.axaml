<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EnfyLiveScreenClient.ViewModels"
        x:Class="EnfyLiveScreenClient.Views.SenseWidget"
        x:DataType="vm:MainWindowViewModel"
        Width="340" Height="34"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        Topmost="True"
        CanResize="False"
        ShowActivated="False"
        Focusable="False"
        Background="Transparent"
        ShowInTaskbar="False"
        PointerPressed="OnPointerPressed">

    <Border Background="#1E293B" 
            CornerRadius="4" 
            BorderBrush="#334155" 
            BorderThickness="1"
            BoxShadow="0 4 12 0 #60000000">
        <Grid ColumnDefinitions="4, Auto, Auto, 1, Auto, 1, *, Auto">
            <!-- GREEN LEFT ACCENT -->
            <Border Grid.Column="0" 
                    Background="#10B981" 
                    CornerRadius="2,0,0,2" 
                    IsVisible="{Binding IsTrackingActive}" />
            
            <!-- TIMER SECTION -->
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="10,0,4,0"
                        Spacing="6">
                <TextBlock Text="{Binding WidgetTimeDisplay}" 
                           FontSize="14" 
                           FontFamily="Consolas, Monospace"
                           FontWeight="Bold" 
                           Foreground="White" 
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- STATUS DOT -->
            <Ellipse Grid.Column="2" 
                     Width="6" Height="6" 
                     Fill="{Binding WidgetStatusColor}" 
                     Margin="0,0,8,0"
                     VerticalAlignment="Center" 
                     IsVisible="{Binding IsTrackingActive}" />

            <!-- SEPARATOR -->
            <Border Grid.Column="3" Background="#334155" Width="1" Margin="2,6" />

            <!-- BUTTONS SECTION -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="4,0" Spacing="2">
                <!-- STOP BUTTON -->
                <Button Command="{Binding RequestFinishWorkCommand}" 
                        Classes="action-btn"
                        ToolTip.Tip="Finish Work"
                        IsVisible="{Binding IsTrackingActive}">
                    <Panel>
                        <Ellipse Width="22" Height="22" Fill="#334155" />
                        <Rectangle Width="7" Height="7" Fill="#EF4444" />
                    </Panel>
                </Button>

                <!-- PAUSE/BREAK BUTTON -->
                <Button Command="{Binding PauseTrackingCommand}" 
                        Classes="action-btn"
                        ToolTip.Tip="Take a Break"
                        IsVisible="{Binding CanShowPause}">
                    <Panel>
                        <Ellipse Width="22" Height="22" Fill="#334155" />
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                            <Rectangle Width="2" Height="8" Fill="#F59E0B" />
                            <Rectangle Width="2" Height="8" Fill="#F59E0B" />
                        </StackPanel>
                    </Panel>
                </Button>

                <!-- RESUME BUTTON -->
                <Button Command="{Binding StartTrackingCommand}" 
                        Classes="action-btn"
                        ToolTip.Tip="Resume Work"
                        IsVisible="{Binding IsPaused}">
                    <Panel>
                        <Ellipse Width="22" Height="22" Fill="#334155" />
                        <Path Data="M 0,0 L 8,5 L 0,10 Z" Fill="#10B981" Width="8" Height="10" HorizontalAlignment="Center" Margin="2,0,0,0" />
                    </Panel>
                </Button>
            </StackPanel>

            <!-- SEPARATOR -->
            <Border Grid.Column="5" Background="#334155" Width="1" Margin="2,6" />

            <!-- STATUS TEXT -->
            <TextBlock Grid.Column="6" 
                       Text="{Binding TrackingStatusText}" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Foreground="{Binding WidgetStatusColor}" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- EXPAND BUTTON -->
            <Button Grid.Column="7" 
                    Command="{Binding ExpandToFullViewCommand}" 
                    Classes="expand-btn"
                    ToolTip.Tip="Open Dashboard">
                <PathIcon Data="{StaticResource arrow_maximize_regular}" 
                          Width="13" Height="13" 
                          Foreground="#94A3B8" />
            </Button>
        </Grid>
    </Border>

    <Window.Styles>
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.action-btn:pointerover Ellipse">
            <Setter Property="Fill" Value="#475569" />
        </Style>
        
        <Style Selector="Button.expand-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.expand-btn:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
    </Window.Styles>
</Window>
