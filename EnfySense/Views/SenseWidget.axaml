<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EnfyLiveScreenClient.ViewModels"
        x:Class="EnfyLiveScreenClient.Views.SenseWidget"
        x:DataType="vm:MainWindowViewModel"
        Width="320" Height="40"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        Topmost="True"
        CanResize="False"
        Background="Transparent"
        ShowInTaskbar="False"
        PointerPressed="OnPointerPressed">

    <Border Background="#1E293B" 
            CornerRadius="4" 
            BorderBrush="#334155" 
            BorderThickness="1"
            BoxShadow="0 4 12 0 #60000000">
        <Grid ColumnDefinitions="4, Auto, Auto, 1, Auto, 1, *, Auto">
            <!-- GREEN LEFT ACCENT -->
            <Border Grid.Column="0" 
                    Background="#10B981" 
                    CornerRadius="2,0,0,2" 
                    IsVisible="{Binding IsTrackingActive}" />
            
            <!-- TIMER SECTION -->
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="12,0,4,0"
                        Spacing="8">
                <TextBlock Text="{Binding WidgetTimeDisplay}" 
                           FontSize="15" 
                           FontFamily="Consolas, Monospace"
                           FontWeight="Bold" 
                           Foreground="White" 
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- STATUS DOT -->
            <Ellipse Grid.Column="2" 
                     Width="6" Height="6" 
                     Fill="#10B981" 
                     Margin="0,0,10,0"
                     VerticalAlignment="Center" 
                     IsVisible="{Binding IsTrackingActive}" />

            <!-- SEPARATOR -->
            <Border Grid.Column="3" Background="#334155" Width="1" Margin="2,8" />

            <!-- STOP BUTTON -->
            <Button Grid.Column="4" 
                    Command="{Binding RequestFinishWorkCommand}" 
                    Classes="stop-btn"
                    Margin="8,0"
                    IsVisible="{Binding IsTrackingActive}">
                <Panel>
                    <Ellipse Width="24" Height="24" Fill="#334155" />
                    <Rectangle Width="8" Height="8" Fill="White" />
                </Panel>
            </Button>

            <!-- SEPARATOR -->
            <Border Grid.Column="5" Background="#334155" Width="1" Margin="2,8" />

            <!-- STATUS TEXT -->
            <TextBlock Grid.Column="6" 
                       Text="{Binding TrackingStatusText}" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{Binding WidgetStatusColor}" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- EXPAND BUTTON -->
            <Button Grid.Column="7" 
                    Command="{Binding ExpandToFullViewCommand}" 
                    Classes="expand-btn">
                <PathIcon Data="{StaticResource arrow_maximize_regular}" 
                          Width="14" Height="14" 
                          Foreground="#94A3B8" />
            </Button>
        </Grid>
    </Border>

    <Window.Styles>
        <Style Selector="Button.stop-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.stop-btn:pointerover Ellipse">
            <Setter Property="Fill" Value="#475569" />
        </Style>
        
        <Style Selector="Button.expand-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.expand-btn:pointerover">
            <Setter Property="Background" Value="#1AFFFFFF" />
        </Style>
    </Window.Styles>
</Window>
</Window>
